NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=
OWNER_EMAILS=
# Lokale Entwicklung: Die UI behandelt dich auf localhost / 127.0.0.1 immer als Owner (useUser).
# Server-APIs (Supabase profiles.role) sind davon unabhängig.
XENTRAL_BASE_URL=
# Optional: Web-UI-Basis für Beleg-Links (wenn abweichend von XENTRAL_BASE_URL ohne /api)
XENTRAL_APP_BASE_URL=
# Sales-Order-Link in Xentral:
# - Relativer Pfad (mit XENTRAL_APP_BASE_URL oder abgeleitet aus XENTRAL_BASE_URL), z. B. /sales-orders
# - Oder vollständige URL-Vorlage: nur die Auftrags-ID wird angehängt (nach id=), z. B.
#   XENTRAL_SALES_ORDER_WEB_PATH="https://….xentral.biz/app/x1?module=auftrag&action=edit&id="
XENTRAL_SALES_ORDER_WEB_PATH=
XENTRAL_API_ACCOUNT_ID=
XENTRAL_APP_NAME=
XENTRAL_INITKEY=
XENTRAL_KEY=
XENTRAL_PAT=
# true = 5 fiktive Bestellungen mit Adressfehlern (heutiges Datum) zum Testen der Adressfehler-UI
NEXT_PUBLIC_XENTRAL_ADDRESS_DEMO_ORDERS=
# Optional: Seller-Portal-Links zur Bestellnummer (Platzhalter {orderId}, mehrfach nutzbar)
# NEXT_PUBLIC_KAUFLAND_ORDER_URL_TEMPLATE=https://seller.kaufland.com/de/orders/{orderId}
# NEXT_PUBLIC_TIKTOK_ORDER_URL_TEMPLATE=https://seller-eu.tiktok.com/order/detail?order_id={orderId}
# NEXT_PUBLIC_SHOPIFY_ORDER_URL_TEMPLATE=https://dein-shop.myshopify.com/admin/orders/{orderId}
# NEXT_PUBLIC_OTTO_ORDER_URL_TEMPLATE=
# NEXT_PUBLIC_FRESSNAPF_ORDER_URL_TEMPLATE=
AMAZON_SP_API_REFRESH_TOKEN=
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_AWS_ACCESS_KEY_ID=
AMAZON_AWS_SECRET_ACCESS_KEY=
AMAZON_AWS_SESSION_TOKEN=
AMAZON_SP_API_REGION=eu-west-1
AMAZON_SP_API_ENDPOINT=sellingpartnerapi-eu.amazon.com
AMAZON_SP_API_MARKETPLACE_ID=
AMAZON_SP_API_SELLER_ID=
# Optional: IANA-Zeitzone für SP-API orderMetrics mit granularity=Day (Standard: Europe/Berlin)
AMAZON_SALES_GRANULARITY_TIMEZONE=
