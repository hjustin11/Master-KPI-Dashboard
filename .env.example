NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=
OWNER_EMAILS=
# Lokale Entwicklung: Die UI behandelt dich auf localhost / 127.0.0.1 immer als Owner (useUser).
# Server-APIs (Supabase profiles.role) sind davon unabhängig.
XENTRAL_BASE_URL=
# Optional: Web-UI-Basis für Beleg-Links (wenn abweichend von XENTRAL_BASE_URL ohne /api)
XENTRAL_APP_BASE_URL=
# Sales-Order-Link in Xentral:
# - Relativer Pfad (mit XENTRAL_APP_BASE_URL oder abgeleitet aus XENTRAL_BASE_URL), z. B. /sales-orders
# - Oder vollständige URL-Vorlage: nur die Auftrags-ID wird angehängt (nach id=), z. B.
#   XENTRAL_SALES_ORDER_WEB_PATH="https://….xentral.biz/app/x1?module=auftrag&action=edit&id="
XENTRAL_SALES_ORDER_WEB_PATH=
XENTRAL_API_ACCOUNT_ID=
XENTRAL_APP_NAME=
XENTRAL_INITKEY=
XENTRAL_KEY=
XENTRAL_PAT=
# true = 5 fiktive Bestellungen mit Adressfehlern (heutiges Datum) zum Testen der Adressfehler-UI
NEXT_PUBLIC_XENTRAL_ADDRESS_DEMO_ORDERS=
# Optional: Seller-Portal-Links zur Bestellnummer (Platzhalter {orderId}, mehrfach nutzbar)
# NEXT_PUBLIC_KAUFLAND_ORDER_URL_TEMPLATE=https://seller.kaufland.com/de/orders/{orderId}
# NEXT_PUBLIC_TIKTOK_ORDER_URL_TEMPLATE=https://seller-eu.tiktok.com/order/detail?order_id={orderId}
# NEXT_PUBLIC_SHOPIFY_ORDER_URL_TEMPLATE=https://dein-shop.myshopify.com/admin/orders/{orderId}
# NEXT_PUBLIC_OTTO_ORDER_URL_TEMPLATE=
# NEXT_PUBLIC_FRESSNAPF_ORDER_URL_TEMPLATE=
AMAZON_SP_API_REFRESH_TOKEN=
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_AWS_ACCESS_KEY_ID=
AMAZON_AWS_SECRET_ACCESS_KEY=
AMAZON_AWS_SESSION_TOKEN=
AMAZON_SP_API_REGION=eu-west-1
AMAZON_SP_API_ENDPOINT=sellingpartnerapi-eu.amazon.com
AMAZON_SP_API_MARKETPLACE_ID=
AMAZON_SP_API_SELLER_ID=
# Optional: IANA-Zeitzone für SP-API orderMetrics mit granularity=Day (Standard: Europe/Berlin)
AMAZON_SALES_GRANULARITY_TIMEZONE=

# OTTO Market API (OAuth2 Client Credentials)
OTTO_API_BASE_URL=https://api.otto.market
OTTO_API_CLIENT_ID=
OTTO_API_CLIENT_SECRET=
# Mindestens "orders", weitere scopes per Leerzeichen oder Komma
# orders = Bestellungen; für /otto/products zusätzlich products
OTTO_API_SCOPES=orders products

# Kaufland Seller API (HMAC, siehe https://sellerapi.kaufland.com/?page=rest-api)
KAUFLAND_API_BASE_URL=https://sellerapi.kaufland.com
KAUFLAND_CLIENT_KEY=
KAUFLAND_SECRET_KEY=
# Optional: Technology-Partner-Zugang (zusätzliche Header)
# KAUFLAND_PARTNER_CLIENT_KEY=
# KAUFLAND_PARTNER_SECRET_KEY=
KAUFLAND_USER_AGENT=Inhouse_development
KAUFLAND_STOREFRONT=de

# Fressnapf = Mirakl: Basis-URL = Origin aus dem Browser/MMS (nicht api.fressnapf.de — der Host löst oft nicht auf).
# Beispiel DE Prod: https://fressnapfde-prod.mirakl.net
FRESSNAPF_API_BASE_URL=
# API-Key aus dem Mirakl-Backend (ohne „Bearer“-Präfix im Header)
FRESSNAPF_API_KEY=
# Standard: mirakl = Authorization: <Key> · alternativ: bearer | x-api-key
# FRESSNAPF_AUTH_MODE=mirakl
# Standard: /api/orders (OR11) · Pagination: max+offset (FRESSNAPF_PAGE_SIZE_PARAM=max|limit)
# FRESSNAPF_ORDERS_PATH=/api/orders
# FRESSNAPF_PAGE_SIZE_PARAM=max
# FRESSNAPF_AMOUNT_SCALE=100
# Gegen HTTP 429: Pause zwischen Seiten (ms) · Retries bei 429
# FRESSNAPF_PAGINATION_DELAY_MS=450
# FRESSNAPF_MAX_429_RETRIES=8
# Mirakl OR11: Zeitraum-Filter (weniger Requests) — bei Problemen: FRESSNAPF_USE_ORDER_DATE_FILTER=false
# FRESSNAPF_USE_ORDER_DATE_FILTER=true

# MediaMarkt & Saturn (Mirakl Seller API — gleiches Muster wie Fressnapf)
MMS_API_BASE_URL=
MMS_API_KEY=
# MMS_AUTH_MODE=mirakl
# MMS_ORDERS_PATH=/api/orders

# ZooPlus (Mirakl Seller API)
ZOOPLUS_API_BASE_URL=
ZOOPLUS_API_KEY=
# ZOOPLUS_AUTH_MODE=mirakl

# Shopify Admin API (Shop-URL + Admin API Access Token)
SHOPIFY_API_BASE_URL=
SHOPIFY_API_KEY=
# SHOPIFY_AUTH_MODE=shopify
# SHOPIFY_ORDERS_PATH=/admin/api/2024-10/orders.json

# TikTok — Hinweis: Offizielle TikTok Shop Open API (partner.tiktokshop.com) nutzt signierte
# Requests, andere Pfade und meist POST. GET {BASE}/orders mit Basic-Auth liefert oft eine
# HTML-Webseite (HTTP 200) statt JSON. Für TikTok braucht ihr typisch ein eigenes Backend/Proxy
# oder eine angepasste Integration — nicht nur die Seller-Portal-URL als TIKTOK_API_BASE_URL.
TIKTOK_API_BASE_URL=
TIKTOK_CLIENT_KEY=
TIKTOK_SECRET_KEY=
# TIKTOK_AUTH_MODE=basic
# TIKTOK_ORDERS_PATH=/orders
